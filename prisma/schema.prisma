// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Using Supabase Cloud PostgreSQL
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique // Integration hook for Clerk Auth
  email     String   @unique
  firstName String?
  lastName  String?
  role      String   @default("SEEKER") // Defines RBAC: "SEEKER" or "RECRUITER"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  profile      Profile?
  jobsPosted   Job[]       @relation("RecruiterJobs")
  applications Applicant[]
  savedJobs    SavedJob[]
}

model Profile {
  id         String   @id @default(uuid())
  userId     String   @unique
  skills     String   // Stored as a comma-separated string
  experience Int      @default(0)
  resumeUrl  String?  // Public URL to the PDF stored in Supabase Storage
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id          String   @id @default(uuid())
  title       String
  company     String
  location    String
  type        String
  salary      String
  description String
  skills      String   // Stored as a comma-separated string
  postedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  recruiterId String
  recruiter   User        @relation("RecruiterJobs", fields: [recruiterId], references: [id])
  applicants  Applicant[]
  savedBy     SavedJob[]
}

model Applicant {
  id         String   @id @default(uuid())
  jobId      String
  userId     String
  matchScore Int
  skills     String   // Stored as comma-separated string
  experience Int
  status     String   @default("Applied") // Stages: Applied, Screening, Interview, Offered, Rejected
  appliedAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Prevent multiple applications to the same job
  @@unique([jobId, userId]) 
}

model SavedJob {
  id        String   @id @default(uuid())
  userId    String
  jobId     String
  savedAt   DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

